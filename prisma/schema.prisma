generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Índices para busca/filtro rápidos com ~15k linhas em produção.

model Usuario {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  nome      String
  senhaHash String
  papel     String   @default("produtor") // admin | produtor
  criadoEm  DateTime @default(now())
}

model Local {
  id             Int       @id @default(autoincrement())
  token          String    @unique
  nome           String
  tipo           String? // Espaço, Restaurante, Auditório, Hotel, Teatro, Cinema...
  endereco       String?
  bairro         String?
  cidade         String?
  uf             String?
  cep            String?
  site           String?
  instagram      String?
  telefone       String?
  telefoneDigits String?
  email          String?
  capacidade     Int? // capacidade máxima de pessoas
  capacidadeNota String? // observação sobre a capacidade (ex.: "300 sentados / 500 em pé")
  descricao      String?
  lat            Float?
  lng            Float?
  origem         String    @default("cadastro")
  status         String    @default("pendente")
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt

  @@index([tipo])
  @@index([uf])
  @@index([cidade])
}

model Fornecedor {
  id                 Int       @id @default(autoincrement())
  token              String    @unique
  nome               String
  razaoSocial        String?
  cnpj               String?
  inscricaoMunicipal String?
  endereco           String? // rua / logradouro
  numero             String?
  complemento        String?
  bairro             String?
  cidade             String?
  uf                 String?
  cep                String?
  categoria          String?
  servicos           String?
  regioes            String?
  contato            String?
  telefone           String?
  telefoneDigits     String?
  email              String?
  site               String?
  instagram          String?
  observacoes        String?
  banco              String?
  agencia            String?
  conta              String?
  pix                String?
  regimeTributario   String? // MEI | Simples | Lucro Presumido | Lucro Real
  cpfPagamento       String?
  origem             String    @default("cadastro")
  status             String    @default("pendente")
  rsvpEnviadoEm      DateTime?
  rsvpEmailEnviadoEm DateTime?
  emailErroEm        DateTime? // e-mail não entregue (bounce/bloqueio via webhook Brevo)
  emailErroMotivo    String?
  wppEntregueEm      DateTime? // RSVP de WhatsApp entregue (status "delivered" do webhook)
  wppLidoEm          DateTime? // RSVP de WhatsApp lido (status "read")
  wppErroEm          DateTime? // WhatsApp não entregue (número sem WhatsApp ou nos bloqueou)
  wppErroMotivo      String?
  notaMedia          Float?
  numAvaliacoes      Int       @default(0)
  avaliacoes         Avaliacao[]
  criadoEm           DateTime  @default(now())
  atualizadoEm       DateTime  @updatedAt

  @@index([categoria])
  @@index([uf])
  @@index([status])
  @@index([telefoneDigits])
}

model Configuracao {
  chave String @id
  valor String
}

// controla a resposta automática do WhatsApp (1 por contato a cada 24h)
model WhatsappAutoReply {
  fone      String   @id
  enviadaEm DateTime @default(now())
}

model Avaliacao {
  id           Int        @id @default(autoincrement())
  fornecedorId Int
  fornecedor   Fornecedor @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)
  usuarioNome  String?
  nota         Int // 1 a 5
  comentario   String?
  evento       String?
  criadoEm     DateTime   @default(now())

  @@index([fornecedorId])
}
