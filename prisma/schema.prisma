generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Índices para busca/filtro rápidos com ~15k linhas em produção.

model Usuario {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  nome      String
  senhaHash String
  papel     String   @default("produtor") // admin | produtor
  criadoEm  DateTime @default(now())
}

model Local {
  id             Int       @id @default(autoincrement())
  token          String    @unique
  nome           String
  tipo           String? // Espaço, Restaurante, Auditório, Hotel, Teatro, Cinema...
  endereco       String?
  bairro         String?
  cidade         String?
  uf             String?
  cep            String?
  site           String?
  instagram      String?
  telefone       String?
  telefoneDigits String?
  email          String?
  capacidade     Int? // capacidade máxima de pessoas
  capacidadeNota String? // observação sobre a capacidade (ex.: "300 sentados / 500 em pé")
  descricao      String?
  lat            Float?
  lng            Float?
  origem         String    @default("cadastro")
  status         String    @default("pendente")
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt

  @@index([tipo])
  @@index([uf])
  @@index([cidade])
}

model Fornecedor {
  id                 Int       @id @default(autoincrement())
  token              String    @unique
  nome               String
  razaoSocial        String?
  cnpj               String?
  inscricaoMunicipal String?
  endereco           String?
  bairro             String?
  cidade             String?
  uf                 String?
  cep                String?
  categoria          String?
  servicos           String?
  regioes            String?
  contato            String?
  telefone           String?
  telefoneDigits     String?
  email              String?
  site               String?
  instagram          String?
  observacoes        String?
  origem             String    @default("cadastro")
  status             String    @default("pendente")
  rsvpEnviadoEm      DateTime?
  criadoEm           DateTime  @default(now())
  atualizadoEm       DateTime  @updatedAt

  @@index([categoria])
  @@index([uf])
  @@index([status])
  @@index([telefoneDigits])
}
